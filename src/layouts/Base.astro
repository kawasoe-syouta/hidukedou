---
import "../styles/global.css";
import { SITE } from "../lib/site.js";

const { title, description } = Astro.props;
const pageTitle = title ? `${title}｜${SITE.name}` : `${SITE.name}｜${SITE.tagline}`;
const desc = description ?? SITE.description;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#2b5876" />
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7405074438692646"
      crossorigin="anonymous"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="site-name" href="/">{SITE.name}</a>
        <span class="site-tagline">{SITE.tagline}</span>
      </div>
    </header>
    <main>
      <div class="wrap">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="wrap">
        <nav>
          <a href="/">ツール一覧</a>
          <a href="/about/">運営者情報</a>
          <a href="/privacy/">プライバシーポリシー</a>
          <a href="/contact/">お問い合わせ</a>
        </nav>
        <p>
          本サイトの計算結果は一般的な数え方に基づく参考情報です。手続きの期限や法要の日取りなど重要な判断は、必ず公的機関・専門家・関係先にご確認ください。
        </p>
        <p>© {new Date().getFullYear()} {SITE.name}</p>
      </div>
    </footer>
  </body>
</html>
