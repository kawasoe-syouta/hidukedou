---
import ToolLayout from "../layouts/ToolLayout.astro";

const faqs = [
  {
    q: "四十九日はいつですか？数え方を教えてください。",
    a: "亡くなった日（命日）を1日目として数えて49日目が四十九日です。日付の計算では「命日に48日を足した日」になります。たとえば7月1日が命日なら、四十九日は8月18日です。",
  },
  {
    q: "四十九日が平日の場合はどうすればよいですか？",
    a: "参列者が集まりやすいよう、四十九日当日より前の土曜日や日曜日に繰り上げて法要を営むのが一般的です。法要は当日より遅らせない（繰り下げない）のがならわしとされています。本ツールでは繰り上げ候補となる直前の土日も表示します。",
  },
  {
    q: "関西では数え方が違うと聞きました。",
    a: "関西の一部地域には、亡くなった前日から数える（逮夜＝たいやを基準にする）風習があり、その場合は法要の日取りが1日早くなります。地域やお寺のならわしによって異なるため、菩提寺や葬儀社に確認するのが確実です。",
  },
  {
    q: "友引や仏滅など六曜は気にしたほうがよいですか？",
    a: "六曜はもともと仏教とは関係がなく、法要の日取りで六曜を避ける必要はないとされるのが一般的です。「友引に葬儀を避ける」風習は火葬場の休業日と重なることが多いため残っていますが、四十九日などの法要には当てはまりません。",
  },
  {
    q: "一周忌や三回忌はいつですか？",
    a: "一周忌は亡くなった翌年の祥月命日（同じ月日）、三回忌は満2年目の祥月命日です。回忌は「数え」で数えるため、三回忌＝2年後、七回忌＝6年後のように、回忌の数から1を引いた年数後になります。",
  },
  {
    q: "納骨は四十九日にするものですか？",
    a: "決まりはありませんが、四十九日法要に合わせて納骨する家庭が多いです。お墓の準備が間に合わない場合は、百箇日や一周忌、お彼岸などに行っても問題ありません。納骨には埋葬許可証が必要なので、当日までに手元にあるか確認しておきましょう。",
  },
  {
    q: "香典返しはいつ送りますか？",
    a: "伝統的には忌明け（四十九日）後の1か月以内を目安に、挨拶状を添えて送ります。最近は通夜・葬儀の当日にお返しする「当日返し」も増えていますが、高額の香典をいただいた方には忌明け後に改めて差額分をお返しするのが丁寧とされています。",
  },
];

const keyPoints = [
  "四十九日は<strong>命日を1日目</strong>として数えて49日目（日付の計算では命日＋48日）",
  "当日が平日なら<strong>直前の土日に繰り上げる</strong>のが一般的（後ろには延ばさない）",
  "友引・仏滅などの六曜は、法要の日取りでは気にしなくてよい",
];

const related = [
  { href: "/column/meinichi/", label: "コラム: 祥月命日と月命日の違い — 回忌の数え方" },
  { href: "/column/rokuyo/", label: "コラム: 六曜とは？法要の日取りと六曜の関係" },
  { href: "/column/shonichi/", label: "コラム: 「初日を含める・含めない」日数の数え方の基本" },
  { href: "/eigyobi/", label: "営業日計算 — 諸手続きの期日確認に" },
];
---

<ToolLayout
  title="四十九日はいつ？計算ツール — 命日から法要の日程を自動計算"
  description="命日を入力するだけで、初七日・四十九日・百箇日・一周忌・三回忌などの法要日を一覧表示。四十九日が平日の場合の繰り上げ候補（直前の土日）も表示します。数え方の解説つき。"
  h1="四十九日・法要日の計算"
  lead="命日（亡くなった日）を入力すると、初七日から三十三回忌までの法要の日付を一覧で計算します。"
  keyPoints={keyPoints}
  faqs={faqs}
  related={related}
>
  <div class="calc" slot="calc">
    <div class="row">
      <div>
        <label for="death-date">命日（亡くなった日）</label>
        <input type="date" id="death-date" />
      </div>
      <button type="button" class="btn" id="calc-btn">計算する</button>
    </div>
    <div id="result" aria-live="polite"></div>
  </div>

  <Fragment slot="explain">
    <h2>四十九日の数え方</h2>
    <p>
      四十九日（しじゅうくにち）は、<strong>命日を1日目として数えて49日目</strong>に営む法要です。仏教では、故人は七日ごとに閻魔大王らの審判を受け、49日目に来世の行き先が定まるとされ、この日をもって忌明け（きあけ）となります。「満中陰（まんちゅういん）」とも呼ばれます。
    </p>
    <p>
      命日を1日目と数えるため、日付の計算上は「命日＋48日」となります。「49日を足す」と1日ずれてしまうので注意してください。初七日（7日目）も同様に「命日＋6日」です。
    </p>
    <h2>実際の日取りの決め方</h2>
    <p>
      四十九日当日が平日の場合は、参列者が集まりやすい<strong>直前の土日に繰り上げる</strong>のが一般的です。忌明け前に済ませる意味から、当日より後に延ばすことは避けるならわしです。本ツールの結果にも繰り上げ候補の土日を表示しています。
    </p>
    <p>
      なお、地域の風習（関西の一部の逮夜基準など）やお寺の考え方で日取りが変わることがあります。最終的な日程は菩提寺・僧侶・葬儀社と相談して決めてください。
    </p>
    <h2>計算例 — 命日から四十九日を求める</h2>
    <table class="milestones">
      <tr><th>命日</th><th>四十九日（命日＋48日）</th></tr>
      <tr><td>1月10日</td><td class="date-cell">2月27日</td></tr>
      <tr><td>3月1日</td><td class="date-cell">4月18日</td></tr>
      <tr><td>7月1日</td><td class="date-cell">8月18日</td></tr>
      <tr><td>12月15日</td><td class="date-cell">翌年2月1日</td></tr>
    </table>
    <p class="small">月末近くが命日の場合や年をまたぐ場合は暗算で間違えやすいので、本ツールでの確認をおすすめします。</p>
    <h2>七日ごとの法要にはそれぞれ名前があります</h2>
    <p>四十九日までの間、七日ごとの節目にはそれぞれ呼び名があります。</p>
    <table class="milestones">
      <tr><th>法要</th><th>読み</th><th>日数</th></tr>
      <tr><td>初七日</td><td>しょなのか</td><td class="date-cell">7日目</td></tr>
      <tr><td>二七日</td><td>ふたなのか</td><td class="date-cell">14日目</td></tr>
      <tr><td>三七日</td><td>みなのか</td><td class="date-cell">21日目</td></tr>
      <tr><td>四七日</td><td>よなのか</td><td class="date-cell">28日目</td></tr>
      <tr><td>五七日</td><td>いつなのか<span class="sub">三十五日とも</span></td><td class="date-cell">35日目</td></tr>
      <tr><td>六七日</td><td>むなのか</td><td class="date-cell">42日目</td></tr>
      <tr class="is-main"><td>七七日（四十九日）</td><td>なななのか</td><td class="date-cell">49日目</td></tr>
    </table>
    <p>
      現在は<strong>初七日を葬儀当日に繰り上げて営む</strong>（式中初七日・繰り上げ初七日）ことが多く、二七日から六七日は省略または自宅での供養にとどめる家庭が増えています。地域や宗派により、五七日（三十五日）を忌明けとする場合もあります。
    </p>
    <h2>忌明けまでに・忌明け後にやること</h2>
    <ul>
      <li><strong>本位牌の準備</strong> — 葬儀で使った白木の位牌は仮のものです。四十九日法要で本位牌に魂を移すため、法要の1〜2週間前までに仏具店などで用意します（文字入れに日数がかかります）。</li>
      <li><strong>納骨</strong> — 四十九日法要と同じ日に行うことが多いですが、決まりはありません。お墓や納骨堂の準備が整ってからで構いません。</li>
      <li><strong>香典返し</strong> — 忌明け後1か月以内を目安に、挨拶状を添えて送るのが伝統的な形です。</li>
      <li><strong>神棚封じの解除</strong> — 神棚のある家では、忌明けをもって神棚に貼った白紙を外します。</li>
    </ul>
  </Fragment>
</ToolLayout>

<script>
  import { parseYmd, toYmd, formatJa, memorialServices, addDays } from "../lib/dateCore.js";
  import { himekuriHTML, milestoneTableHTML, shareButtonHTML, bindShareButtons, getParam, setParams } from "../lib/ui.js";

  const $ = (id) => document.getElementById(id);
  const result = $("result");

  function run() {
    const v = $("death-date").value;
    if (!v) return;
    const death = parseYmd(v);
    const items = memorialServices(death).map((it) => ({
      ...it,
      main: it.label.includes("四十九日"),
    }));
    const shijukunichi = items.find((it) => it.main).date;

    // 平日なら直前の土日を繰り上げ候補として表示
    let kuriage = "";
    const w = shijukunichi.getDay();
    if (w >= 1 && w <= 5) {
      const sun = addDays(shijukunichi, -w);
      const sat = addDays(sun, -1);
      kuriage = `<p class="result-note">四十九日当日は平日です。繰り上げて営む場合の直前の週末は ${formatJa(sat)}・${formatJa(sun)} です。</p>`;
    }

    result.innerHTML = `
      <p class="result-caption">四十九日（忌明け）は</p>
      ${himekuriHTML(shijukunichi)}
      ${kuriage}
      ${milestoneTableHTML(items, { firstColLabel: "法要" })}
      ${shareButtonHTML()}
      <p class="result-note">命日を1日目として計算しています。地域・宗派のならわしにより日取りが異なる場合があります。</p>`;
    bindShareButtons(result);
    setParams({ d: toYmd(death) });
  }

  $("calc-btn").addEventListener("click", run);
  const p = getParam("d");
  if (p) {
    $("death-date").value = p;
    run();
  }
</script>
