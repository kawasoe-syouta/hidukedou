// Cloudflare Workers の設定。静的サイトとして dist/ を配信する
{
  "name": "hidukedou",
  "compatibility_date": "2026-07-05",
  "assets": {
    "directory": "./dist"
  },
  // カスタムドメイン。deploy時に自動でDNSレコードとSSL証明書が設定される
  "routes": [
    { "pattern": "hizukedo.com", "custom_domain": true },
    { "pattern": "www.hizukedo.com", "custom_domain": true }
  ]
}
